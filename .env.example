# VSCodeux Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# DATABASE (Supabase) - REQUIRED
# ============================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# AI PROVIDERS
# ============================================
# v0 AI Gateway: No API key needed (default, zero config)
# For other providers, set the appropriate key:

# OpenAI Direct (optional - if not using AI Gateway)
OPENAI_API_KEY=

# Anthropic Direct (optional - if not using AI Gateway)
ANTHROPIC_API_KEY=

# Google AI Direct (optional - if not using AI Gateway)
GOOGLE_AI_API_KEY=

# xAI/Groq/Other AI Gateway Providers (requires key)
AI_GATEWAY_API_KEY=

# OpenRouter (optional - for 200+ models)
OPENROUTER_API_KEY=

# ============================================
# RATE LIMITING (Upstash Redis) - RECOMMENDED
# ============================================
# Get these from Upstash Console
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================
# GitHub (for git operations)
GITHUB_TOKEN=

# Vercel (for deployments)
VERCEL_TOKEN=

# Sentry (for error tracking)
SENTRY_DSN=

# ============================================
# APP CONFIGURATION
# ============================================
# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment
NODE_ENV=development
